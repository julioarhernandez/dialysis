---
import Layout from '../layouts/Layout.astro';
import PatientCare from '../components/PatientCare.astro';
import CtaStrip from '../components/CtaStrip.astro';
---
<Layout
  title="Patient Care — Global Dialysis Care Center"
  description="Personalized care plans, emotional support, and patient education at every step of your dialysis journey."
>
  <!-- Page hero -->
  <section class="py-[88px] px-6 md:px-24 bg-white border-b border-hair">
    <div class="max-w-[1248px] mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 border border-hair rounded-full bg-white font-mono text-[11px] text-brand-deep tracking-[0.06em] uppercase mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-aqua"></span>
        Patient care
      </div>
      <h1 class="font-display font-medium text-[56px] md:text-[72px] leading-[1.04] tracking-[-0.025em] text-ink m-0 max-w-[760px]" style="text-wrap:pretty;">
        Support that extends far beyond the clinical setting.
      </h1>
      <p class="mt-6 text-[18px] md:text-[20px] text-muted max-w-[580px] leading-[1.5]">
        Personalized plans, family support, and continuous education — because great care
        means treating the whole person, not just the condition.
      </p>
    </div>
  </section>

  <PatientCare />

  <CtaStrip
    title="Have questions about your care?"
    description="Our care team is a call or message away."
    buttons={[
      { label: "Get in touch", href: "/contact" }
    ]}
  />
</Layout>
