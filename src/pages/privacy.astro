---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site.js';

const { contact } = SITE;
---
<Layout
  title={`Privacy Policy — ${SITE.name}`}
  description="How Global Dialysis Care Center collects, uses, and protects information submitted through this website."
>

  <!-- Page header -->
  <div class="bg-brand-deep text-white px-6 py-16 md:px-24">
    <div class="max-w-[1248px] mx-auto">
      <div class="font-mono text-[11px] text-aqua tracking-[0.16em] uppercase mb-4">Legal</div>
      <h1 class="font-display font-medium text-[42px] leading-[1.05] tracking-[-0.03em] text-white m-0">
        Privacy Policy
      </h1>
      <p class="mt-3 text-white/70 text-[15px]">Effective date: January 1, 2026</p>
    </div>
  </div>

  <!-- Content -->
  <div class="px-6 py-16 md:px-24 bg-white">
    <div class="max-w-[760px] mx-auto prose-legal">

      <p>This Privacy Policy describes how {SITE.name} ("we," "us," or "our") collects and uses information submitted through this website (<strong>globaldialysiscare.com</strong>). It applies only to this website and does not govern the privacy of health information we collect as part of your clinical care — that is covered separately in our <a href="/hipaa" class="text-brand font-medium no-underline hover:underline">HIPAA Notice of Privacy Practices</a>.</p>

      <h2>1. Information We Collect</h2>
      <p>When you submit our contact form, we collect the information you provide voluntarily: your name, email address, phone number, and the content of your message. We do not collect this information automatically — only when you choose to submit the form.</p>
      <p>This website does not use tracking cookies, analytics scripts, or advertising pixels. We do not collect IP addresses, browsing history, or device identifiers.</p>

      <h2>2. How We Use Your Information</h2>
      <p>We use the information you submit solely to respond to your inquiry or consultation request. Your contact details are used to reach you by phone or email within one business day, as described when you submit the form.</p>

      <h2>3. Third-Party Form Processing</h2>
      <p>Contact form submissions are processed through <strong>Web3Forms</strong> (web3forms.com), a third-party form service. Submissions are transmitted securely to Web3Forms' servers and forwarded to our care team's email inbox. We do not store your form data on our own servers. Web3Forms' privacy practices are governed by their own privacy policy.</p>

      <h2>4. How We Protect Your Information</h2>
      <p>All data transmitted between your browser and this website is encrypted via HTTPS. We do not sell, rent, trade, or share your contact information with third parties for marketing purposes.</p>

      <h2>5. Data Retention</h2>
      <p>Form submissions are retained in our email inbox for the purpose of following up on your inquiry. Once your inquiry is resolved, records may be kept for a reasonable period consistent with standard business practice. If you would like your contact information removed, please reach out to us directly.</p>

      <h2>6. Children's Privacy</h2>
      <p>This website is not directed to children under 13. We do not knowingly collect information from children. If you believe a child has submitted information through this site, please contact us so we can remove it.</p>

      <h2>7. Links to Other Websites</h2>
      <p>This website may contain links to third-party websites (such as insurance provider sites). We are not responsible for the privacy practices of those sites and encourage you to review their policies.</p>

      <h2>8. Changes to This Policy</h2>
      <p>We may update this Privacy Policy from time to time. The effective date at the top of this page will reflect the most recent revision. Continued use of this website after changes are posted constitutes acceptance of the updated policy.</p>

      <h2>9. Contact Us</h2>
      <p>If you have questions about this Privacy Policy, please contact us:</p>
      <address class="not-italic mt-2 text-[15px] text-ink">
        <strong>{SITE.name}</strong><br/>
        {contact.address}<br/>
        {contact.city}, {contact.state} {contact.zip}<br/>
        <a href={`mailto:${contact.email}`} class="text-brand no-underline hover:underline">{contact.email}</a><br/>
        <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="text-brand no-underline hover:underline">{contact.phone}</a>
      </address>

    </div>
  </div>

</Layout>

<style>
  .prose-legal {
    color: #374151;
    font-size: 15.5px;
    line-height: 1.7;
  }
  .prose-legal h2 {
    font-family: var(--font-display, 'Newsreader', serif);
    font-weight: 500;
    font-size: 21px;
    color: #0a1a2c;
    margin-top: 2.4rem;
    margin-bottom: 0.6rem;
    letter-spacing: -0.015em;
  }
  .prose-legal p {
    margin-top: 0;
    margin-bottom: 1rem;
  }
  .prose-legal strong {
    color: #0a1a2c;
    font-weight: 600;
  }
  .prose-legal address {
    background: #f0f6fa;
    border-left: 3px solid #0e4d7a;
    padding: 14px 18px;
    border-radius: 0 8px 8px 0;
  }
</style>
