---
import Layout from '../layouts/Layout.astro';
import Services from '../components/Services.astro';
import Insurance from '../components/Insurance.astro';
---
<Layout
  title="Our Services — Global Dialysis Care Center"
  description="Three dialysis treatment paths: in-patient hemodialysis, home hemodialysis, and peritoneal dialysis."
>
  <!-- Page hero -->
  <section class="py-[88px] px-6 md:px-24 bg-white border-b border-hair">
    <div class="max-w-[1248px] mx-auto">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 border border-hair rounded-full bg-white font-mono text-[11px] text-brand-deep tracking-[0.06em] uppercase mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-aqua"></span>
        Our services
      </div>
      <h1 class="font-display font-medium text-[56px] md:text-[72px] leading-[1.04] tracking-[-0.025em] text-ink m-0 max-w-[760px]" style="text-wrap:pretty;">
        Three paths. One steady team beside you.
      </h1>
      <p class="mt-6 text-[18px] md:text-[20px] text-muted max-w-[580px] leading-[1.5]">
        We offer in-center, home, and peritoneal dialysis — each explained clearly
        so you and your family can make the right choice together.
      </p>
    </div>
  </section>

  <Services />
  <Insurance />
</Layout>
