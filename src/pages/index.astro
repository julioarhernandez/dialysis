---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import PatientCare from '../components/PatientCare.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import Insurance from '../components/Insurance.astro';
import CtaStrip from '../components/CtaStrip.astro';
---
<Layout title="Global Dialysis Care Center — High-quality renal care">
  <Hero />
  <TrustBar />
  <About />
  <Services />
  <PatientCare />
  <WhyChooseUs />
  <Testimonials />
  <FAQ />
  <Insurance />

  <CtaStrip
    title="Ready to take the next step?"
    description="Our care team is here to walk with you — at your pace, on your terms."
    buttons={[
      { label: "Schedule a consultation", href: "/contact" },
      { label: "Explore our services", href: "/services", variant: "secondary" }
    ]}
  />
</Layout>
