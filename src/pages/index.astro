---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import About from '../components/About.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Testimonials from '../components/Testimonials.astro';
---
<Layout title="Global Dialysis Care Center — High-quality renal care">
  <Hero />
  <TrustBar />
  <About />
  <WhyChooseUs />
  <Testimonials />

  <!-- Home CTA strip -->
  <section class="py-[88px] px-6 md:px-24 bg-tint">
    <div class="max-w-[1248px] mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <div>
        <h2 class="font-display font-medium text-[32px] leading-[1.1] tracking-[-0.022em] text-ink m-0">
          Ready to take the next step?
        </h2>
        <p class="mt-3 text-[17px] text-muted">Our care team is here to walk with you — at your pace, on your terms.</p>
      </div>
      <div class="flex gap-3 flex-wrap">
        <a
          href="/contact"
          class="inline-flex items-center gap-2.5 px-[22px] py-[14px] rounded-[10px] bg-brand text-white font-semibold text-sm no-underline"
          style="box-shadow:0 1px 0 rgba(255,255,255,0.2) inset,0 6px 20px rgba(14,77,122,0.20);"
        >
          Schedule a consultation
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a
          href="/services"
          class="inline-flex items-center gap-2.5 px-[22px] py-[14px] rounded-[10px] bg-transparent text-brand-deep font-semibold text-sm no-underline border border-hair hover:border-brand transition-colors"
        >
          Explore our services
        </a>
      </div>
    </div>
  </section>
</Layout>
