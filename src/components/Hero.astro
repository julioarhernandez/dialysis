---
---
<section class="relative overflow-hidden border-b border-hair text-white py-14 px-6 md:pt-[112px] md:px-24 md:pb-[120px]">

  <!-- Full-bleed hero photo -->
  <img
    src="/images/hero.png"
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center"
  />

  <!-- Navy scrim -->
  <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(7,45,74,0.80) 0%,rgba(7,45,74,0.67) 55%,rgba(7,45,74,0.87) 100%);" aria-hidden="true"></div>

  <!-- Aqua radial glow (top-right) -->
  <div class="absolute -right-60 -top-40 w-[700px] h-[700px] pointer-events-none" style="background:radial-gradient(circle,rgba(63,186,192,0.20),transparent 60%);" aria-hidden="true"></div>

  <div class="max-w-[1280px] mx-auto relative">

    <!-- Top metadata row -->
    <div class="flex justify-between items-baseline flex-wrap gap-4 mb-12">
      <span class="font-mono text-[11px] text-aqua tracking-[0.18em] uppercase inline-flex items-center gap-2.5">
        <span class="inline-block w-6 h-px bg-aqua opacity-60"></span>
        Renal care · Est. 2008
      </span>
      <span class="font-mono text-[11px] text-white/70 tracking-[0.14em] uppercase">
        San Francisco · Bayfront Plaza
      </span>
    </div>

    <!-- Headline -->
    <h1 class="font-display font-medium text-[52px] md:text-[136px] leading-[0.94] tracking-[-0.04em] text-white m-0" style="text-wrap:balance;">
      High-quality<br/>
      renal care,<br/>
      <span class="text-aqua italic">designed around you.</span>
    </h1>

    <!-- Bottom strip -->
    <div class="mt-10 md:mt-20 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-14 items-end pt-8 border-t border-white/[0.18]">
      <p class="text-base md:text-[18px] text-white/85 leading-[1.55] max-w-[380px] m-0">
        Personalized dialysis treatment delivered with warmth, expertise,
        and steady support — every step of the journey.
      </p>
      <div class="flex flex-col gap-3.5">
        <span class="font-mono text-[11px] text-aqua tracking-[0.12em] uppercase">Three pillars</span>
        <div class="flex flex-col gap-1 text-sm text-white">
          <span>Clarity of services</span>
          <span>Human-centered care</span>
          <span>Trust &amp; credibility</span>
        </div>
      </div>
      <div class="flex gap-3 flex-wrap md:justify-self-end">
        <a href="/contact" class="inline-flex items-center gap-2.5 px-[22px] py-[14px] rounded-[10px] bg-aqua text-brand-deep font-semibold text-sm no-underline">
          Schedule a consultation
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="/contact" class="inline-flex items-center gap-2.5 px-[22px] py-[14px] rounded-[10px] bg-transparent text-white border border-white/35 font-semibold text-sm no-underline">
          Contact us
        </a>
      </div>
    </div>

  </div>
</section>
