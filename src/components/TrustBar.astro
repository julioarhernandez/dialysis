---
const partners = ['Medicare', 'Blue Cross', 'Aetna', 'Cigna', 'United Health', 'KDOQI'];
---
<div class="border-t border-hair border-b border-hair bg-white">
  <div class="max-w-[1248px] mx-auto px-6 py-5 md:px-24 flex flex-wrap items-center gap-4 md:gap-10 font-mono text-[11px] text-muted tracking-[0.08em] uppercase">
    <span class="text-brand-deep">Accredited &amp; trusted by</span>
    {partners.map(name => (
      <span class="opacity-70">{name}</span>
    ))}
  </div>
</div>
