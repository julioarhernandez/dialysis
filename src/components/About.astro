---
import { ABOUT_PARAGRAPHS, ABOUT_CARDS } from '../data/about.js';
---
<section id="about" class="py-[88px] px-6 md:px-24 bg-white">
  <div class="max-w-[1248px] mx-auto grid grid-cols-1 md:grid-cols-[0.8fr_1.2fr] gap-8 md:gap-20 items-start">

    <!-- Left: section header -->
    <div>
      <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">01 — About us</div>
      <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[540px]" style="text-wrap:pretty;">
        Happiness begins with good health.
      </h2>
    </div>

    <!-- Right: body -->
    <div>
      {ABOUT_PARAGRAPHS.map(p => (
        <p class="text-base md:text-[18px] leading-[1.6] text-muted mb-5 last:mb-7">{p}</p>
      ))}

      <div class="flex flex-wrap gap-4">
        {ABOUT_CARDS.map(card => (
          <div class="flex items-start gap-3.5 p-4 rounded-[14px] bg-white border border-hair flex-[1_1_240px]">
            <div class="w-[38px] h-[38px] rounded-[10px] bg-tint flex items-center justify-center flex-shrink-0 text-brand">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={card.icon}/>
            </div>
            <div>
              <div class="font-semibold text-sm text-ink">{card.title}</div>
              <div class="text-[12.5px] text-muted mt-0.5">{card.sub}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
