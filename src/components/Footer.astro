---
import { SITE, FOOTER_COLUMNS } from '../data/site.js';

const { contact } = SITE;

const contactCol = {
  title: 'Contact',
  links: [
    { label: contact.phone,                             href: `tel:${contact.phone.replace(/\s/g, '')}` },
    { label: contact.email,                             href: `mailto:${contact.email}` },
    { label: contact.address,                           href: '/contact' },
    { label: `${contact.city}, ${contact.state} ${contact.zip}`, href: '/contact' },
  ],
};

const allCols = [...FOOTER_COLUMNS, contactCol];
---
<footer class="bg-brand-deep text-white/80 px-6 pt-16 pb-8 md:px-24">
  <div class="max-w-[1248px] mx-auto grid grid-cols-1 md:grid-cols-[1.4fr_1fr_1fr_1fr] gap-8">

    <!-- Brand column -->
    <div>
      <a href="/" class="inline-flex items-center gap-2.5 no-underline mb-4">
        <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true">
          <defs>
            <linearGradient id="footer-logo-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#ffffff"/>
              <stop offset="100%" stop-color="#3fbac0"/>
            </linearGradient>
          </defs>
          <circle cx="18" cy="18" r="18" fill="url(#footer-logo-grad)"/>
          <path d="M18 8 C 24 14, 26 20, 18 26 C 10 20, 12 14, 18 8 Z" fill="rgba(255,255,255,0.95)"/>
        </svg>
        <div>
          <div class="text-white font-display font-bold text-[15px]">{SITE.shortName}</div>
          <div class="text-white/60 text-xs">Care Center</div>
        </div>
      </a>
      <p class="text-[13.5px] leading-[1.55] text-white/70 max-w-[320px]">
        {SITE.description}
      </p>
    </div>

    <!-- Link columns -->
    {allCols.map(col => (
      <div>
        <div class="text-white text-xs font-semibold tracking-[0.06em] uppercase mb-3.5">{col.title}</div>
        <ul class="list-none p-0 m-0 flex flex-col gap-2 text-[13.5px]">
          {col.links.map(link => (
            <li>
              <a href={link.href} class="text-white/70 no-underline hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="max-w-[1248px] mx-auto mt-10 pt-6 border-t border-white/10 flex flex-wrap justify-between gap-4 text-xs text-white/55">
    <span>© 2026 {SITE.name} · {contact.city}, {contact.state} · by <a href="https://bizmarketing.us" target="_blank" rel="noopener noreferrer" class="text-white/55 no-underline hover:text-white transition-colors">Bizmarketing.us</a></span>
    <span class="flex flex-wrap gap-x-4 gap-y-1">
      <a href="/privacy" class="text-white/55 no-underline hover:text-white transition-colors">Privacy Policy</a>
      <a href="/accessibility" class="text-white/55 no-underline hover:text-white transition-colors">Accessibility</a>
      <a href="/hipaa" class="text-white/55 no-underline hover:text-white transition-colors">HIPAA Notice</a>
    </span>
  </div>
</footer>
