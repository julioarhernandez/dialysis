---
---
<section class="py-[88px] px-6 md:px-24 bg-tint">
  <div class="max-w-[1248px] mx-auto">

    <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">02 — Our services</div>
    <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[720px]" style="text-wrap:pretty;">
      Three paths. One steady team beside you.
    </h2>
    <p class="mt-4 text-[17px] text-muted max-w-[640px] leading-[1.5]">
      Each treatment option is presented with clarity, empathy, and reassurance — helping patients
      and families understand their choices with confidence.
    </p>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-5">

      <!-- Card 1: In-Patient Hemodialysis -->
      <article class="bg-white rounded-[20px] overflow-hidden border border-hair flex flex-col">
        <div class="h-[180px] relative border-b border-hair">
          <!-- IllustrationMonitor -->
          <svg viewBox="0 0 600 400" preserveAspectRatio="xMidYMid slice" class="w-full h-full block" aria-hidden="true">
            <rect width="600" height="400" fill="#e6eff5"/>
            <g stroke="#0e4d7a" stroke-opacity="0.18" stroke-width="1">
              <line x1="0" y1="0" x2="600" y2="0"/><line x1="0" y1="40" x2="600" y2="40"/>
              <line x1="0" y1="80" x2="600" y2="80"/><line x1="0" y1="120" x2="600" y2="120"/>
              <line x1="0" y1="160" x2="600" y2="160"/><line x1="0" y1="200" x2="600" y2="200"/>
              <line x1="0" y1="240" x2="600" y2="240"/><line x1="0" y1="280" x2="600" y2="280"/>
              <line x1="0" y1="320" x2="600" y2="320"/><line x1="0" y1="360" x2="600" y2="360"/>
            </g>
            <path d="M40 220 L160 220 L185 160 L210 280 L235 200 L260 220 L380 220 L405 180 L430 250 L455 220 L580 220"
              fill="none" stroke="#0e4d7a" stroke-width="3" stroke-linejoin="round" stroke-linecap="round"/>
            <circle cx="210" cy="280" r="5" fill="#3fbac0"/>
            <circle cx="430" cy="250" r="5" fill="#3fbac0"/>
          </svg>
          <div class="absolute top-3 left-3 font-mono text-[10px] tracking-[0.1em] uppercase text-brand-deep bg-white/85 px-[10px] py-1 rounded-full">01 / in-patient</div>
        </div>
        <div class="p-6 flex flex-col gap-4 flex-1">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-[10px] bg-tint flex items-center justify-center text-brand flex-shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12h4l2-5 4 10 2-5h6"/>
              </svg>
            </div>
            <h3 class="font-display font-medium text-[19px] m-0 tracking-[-0.012em] text-ink">In-Patient Hemodialysis</h3>
          </div>
          <p class="text-[14.5px] text-muted m-0 leading-[1.55]">
            Designed for hospitalized patients who require close monitoring in an advanced clinical environment.
          </p>
          <ul class="list-none p-0 m-0 flex flex-col gap-2">
            {['Continuous medical supervision', 'Advanced clinical environment', 'Coordinated with hospital teams'].map(b => (
              <li class="flex items-center gap-2.5 text-[13.5px] text-ink">
                <span class="w-[18px] h-[18px] rounded-full bg-tint inline-flex items-center justify-center flex-shrink-0 text-brand">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
                </span>
                {b}
              </li>
            ))}
          </ul>
          <a href="/services" class="mt-auto self-start text-[13px] font-semibold text-brand-deep inline-flex items-center gap-1.5 no-underline pt-1 hover:text-brand">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </article>

      <!-- Card 2: Home Hemodialysis -->
      <article class="bg-white rounded-[20px] overflow-hidden border border-hair flex flex-col">
        <div class="h-[180px] relative border-b border-hair">
          <!-- IllustrationHome -->
          <svg viewBox="0 0 600 500" preserveAspectRatio="xMidYMid slice" class="w-full h-full block" aria-hidden="true">
            <rect width="600" height="500" fill="#e6eff5"/>
            <g transform="translate(300 270)">
              <circle r="170" fill="#ffffff"/>
              <path d="M-90 30 L0 -60 L90 30 L90 100 L-90 100 Z" fill="none" stroke="#0e4d7a" stroke-width="2.5"/>
              <rect x="-22" y="40" width="44" height="60" fill="#3fbac0" fill-opacity="0.5"/>
              <circle cx="60" cy="-30" r="14" fill="#3fbac0"/>
            </g>
            <path d="M0 380 Q 150 320 300 380 T 600 380 L 600 500 L 0 500 Z" fill="#0e4d7a" fill-opacity="0.18"/>
          </svg>
          <div class="absolute top-3 left-3 font-mono text-[10px] tracking-[0.1em] uppercase text-brand-deep bg-white/85 px-[10px] py-1 rounded-full">02 / home dialysis</div>
        </div>
        <div class="p-6 flex flex-col gap-4 flex-1">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-[10px] bg-tint flex items-center justify-center text-brand flex-shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 11l9-7 9 7"/><path d="M5 10v10h14V10"/>
              </svg>
            </div>
            <h3 class="font-display font-medium text-[19px] m-0 tracking-[-0.012em] text-ink">Home Hemodialysis</h3>
          </div>
          <p class="text-[14.5px] text-muted m-0 leading-[1.55]">
            Treatment performed in the comfort of your home, with full training and ongoing nursing support.
          </p>
          <ul class="list-none p-0 m-0 flex flex-col gap-2">
            {['Greater flexibility & independence', 'Comprehensive at-home training', '24/7 nurse support line'].map(b => (
              <li class="flex items-center gap-2.5 text-[13.5px] text-ink">
                <span class="w-[18px] h-[18px] rounded-full bg-tint inline-flex items-center justify-center flex-shrink-0 text-brand">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
                </span>
                {b}
              </li>
            ))}
          </ul>
          <a href="/services" class="mt-auto self-start text-[13px] font-semibold text-brand-deep inline-flex items-center gap-1.5 no-underline pt-1 hover:text-brand">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </article>

      <!-- Card 3: Peritoneal Dialysis -->
      <article class="bg-white rounded-[20px] overflow-hidden border border-hair flex flex-col">
        <div class="h-[180px] relative border-b border-hair">
          <!-- IllustrationCare -->
          <svg viewBox="0 0 600 700" preserveAspectRatio="xMidYMid slice" class="w-full h-full block" aria-hidden="true">
            <defs>
              <linearGradient id="svc-care-bg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#e6eff5"/>
                <stop offset="100%" stop-color="#ffffff"/>
              </linearGradient>
              <linearGradient id="svc-care-arc" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#3fbac0" stop-opacity="0.85"/>
                <stop offset="100%" stop-color="#0e4d7a" stop-opacity="0.95"/>
              </linearGradient>
            </defs>
            <rect width="600" height="700" fill="url(#svc-care-bg)"/>
            <g transform="translate(300 540)">
              <circle r="380" fill="none" stroke="#0e4d7a" stroke-opacity="0.08" stroke-width="1.5"/>
              <circle r="300" fill="none" stroke="#0e4d7a" stroke-opacity="0.10" stroke-width="1.5"/>
              <circle r="220" fill="none" stroke="#0e4d7a" stroke-opacity="0.14" stroke-width="1.5"/>
              <circle r="140" fill="none" stroke="#0e4d7a" stroke-opacity="0.20" stroke-width="1.5"/>
              <circle r="70" fill="#3fbac0" fill-opacity="0.30"/>
            </g>
            <g transform="translate(300 320)">
              <path d="M0 -160 C 90 -90, 110 60, 0 130 C -110 60, -90 -90, 0 -160 Z" fill="url(#svc-care-arc)"/>
              <path d="M0 -120 C 60 -60, 70 50, 0 95" fill="none" stroke="rgba(255,255,255,0.55)" stroke-width="2"/>
            </g>
            <circle cx="170" cy="180" r="6" fill="#3fbac0"/>
            <circle cx="450" cy="240" r="4" fill="#0e4d7a" fill-opacity="0.5"/>
          </svg>
          <div class="absolute top-3 left-3 font-mono text-[10px] tracking-[0.1em] uppercase text-brand-deep bg-white/85 px-[10px] py-1 rounded-full">03 / peritoneal</div>
        </div>
        <div class="p-6 flex flex-col gap-4 flex-1">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-[10px] bg-tint flex items-center justify-center text-brand flex-shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3c4 5 6 8 6 11a6 6 0 1 1-12 0c0-3 2-6 6-11z"/>
              </svg>
            </div>
            <h3 class="font-display font-medium text-[19px] m-0 tracking-[-0.012em] text-ink">Peritoneal Dialysis</h3>
          </div>
          <p class="text-[14.5px] text-muted m-0 leading-[1.55]">
            Uses your body's natural filtration process — performed at home for greater autonomy.
          </p>
          <ul class="list-none p-0 m-0 flex flex-col gap-2">
            {['Performed at home', 'Promotes autonomy', 'More flexible lifestyle'].map(b => (
              <li class="flex items-center gap-2.5 text-[13.5px] text-ink">
                <span class="w-[18px] h-[18px] rounded-full bg-tint inline-flex items-center justify-center flex-shrink-0 text-brand">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
                </span>
                {b}
              </li>
            ))}
          </ul>
          <a href="/services" class="mt-auto self-start text-[13px] font-semibold text-brand-deep inline-flex items-center gap-1.5 no-underline pt-1 hover:text-brand">
            Learn more
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </article>

    </div>
  </div>
</section>
