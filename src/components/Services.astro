---
import { DIALYSIS_TREATMENTS, SUPPORT_SERVICES } from '../data/services.js';

// Illustration SVGs live here (visual, not content).
// Referenced by the `illustration` key on each DIALYSIS_TREATMENT entry.
const illustrations = {
  monitor: `<img src="/images/Hemodialysis.png" alt="Hemodialysis treatment" class="w-full h-full object-cover" />`,
  home: `<img src="/images/HomeDialysis.png" alt="Home dialysis treatment" class="w-full h-full object-cover" />`,
  care: `<img src="/images/PeritonealDialysis.png" alt="Peritoneal dialysis treatment" class="w-full h-full object-cover" />`,
};
---
<section class="py-[88px] px-6 md:px-24 bg-tint">
  <div class="max-w-[1248px] mx-auto">

    <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">Our services</div>
    <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[720px]" style="text-wrap:pretty;">
      Three paths. One steady team beside you.
    </h2>
    <p class="mt-4 text-[17px] text-muted max-w-[640px] leading-[1.5]">
      Each treatment option is presented with clarity, empathy, and reassurance, helping patients
      and families understand their choices with confidence.
    </p>

    <!-- Dialysis treatment cards -->
    <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-5">
      {DIALYSIS_TREATMENTS.map(svc => (
        <article class="bg-white rounded-[20px] overflow-hidden border border-hair flex flex-col">

          <!-- Illustration + badge (both inside relative container) -->
          <div class="h-[180px] relative border-b border-hair overflow-hidden">
            <div class="absolute inset-0" set:html={illustrations[svc.illustration]}/>
            <span class="absolute top-3 left-3 z-10 font-mono text-[10px] tracking-[0.1em] uppercase text-brand-deep bg-white/85 px-[10px] py-1 rounded-full">
              {svc.badge}
            </span>
          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col gap-4 flex-1">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-[10px] bg-tint flex items-center justify-center text-brand flex-shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon}/>
              </div>
              <h3 class="font-display font-medium text-[19px] m-0 tracking-[-0.012em] text-ink">{svc.title}</h3>
            </div>
            <p class="text-[14.5px] text-muted m-0 leading-[1.55]">{svc.desc}</p>
            <ul class="list-none p-0 m-0 flex flex-col gap-2">
              {svc.bullets.map(b => (
                <li class="flex items-center gap-2.5 text-[13.5px] text-ink">
                  <span class="w-[18px] h-[18px] rounded-full bg-tint inline-flex items-center justify-center flex-shrink-0 text-brand">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
                  </span>
                  {b}
                </li>
              ))}
            </ul>
            <a href="/contact" class="mt-auto self-start text-[13px] font-semibold text-brand-deep inline-flex items-center gap-1.5 no-underline pt-1 hover:text-brand">
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>

        </article>
      ))}
    </div>

    <!-- Support services divider -->
    <div class="mt-20 mb-10 flex items-center gap-6">
      <div class="flex-1 h-px bg-hair"></div>
      <span class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase flex-shrink-0">Comprehensive support services</span>
      <div class="flex-1 h-px bg-hair"></div>
    </div>

    <!-- Support service cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
      {SUPPORT_SERVICES.map(svc => (
        <div class="bg-white rounded-[18px] p-6 border border-hair flex flex-col gap-4">
          <div class="w-11 h-11 rounded-[12px] bg-tint flex items-center justify-center text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon}/>
          </div>
          <div>
            <h3 class="font-display font-medium text-[17px] m-0 mb-2 tracking-[-0.012em] text-ink">{svc.title}</h3>
            <p class="text-[13.5px] text-muted m-0 leading-[1.55]">{svc.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
