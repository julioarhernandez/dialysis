---
interface Button {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

interface Props {
  title: string;
  description: string;
  buttons: Button[];
  reveal?: boolean;
}

const { title, description, buttons, reveal = true } = Astro.props;
---
<section class={`py-[88px] px-6 md:px-24 bg-tint ${reveal ? 'reveal' : ''}`}>
  <div class="max-w-[1248px] mx-auto flex flex-col md:flex-row md:items-center md:justify-between gap-8">
    <div>
      <h2 class="font-display font-medium text-[32px] leading-[1.1] tracking-[-0.022em] text-ink m-0">
        {title}
      </h2>
      <p class="mt-3 text-[17px] text-muted">{description}</p>
    </div>
    <div class="flex gap-3 flex-wrap md:flex-nowrap">
      {buttons.map(btn => (
        <a
          href={btn.href}
          class:list={[
            "inline-flex items-center gap-2.5 px-[22px] py-[14px] rounded-[10px] font-semibold text-sm no-underline transition-colors flex-shrink-0",
            btn.variant === 'secondary' 
              ? "bg-transparent text-brand-deep border border-hair hover:border-brand" 
              : "bg-brand text-white"
          ]}
          style={btn.variant !== 'secondary' ? "box-shadow:0 1px 0 rgba(255,255,255,0.2) inset,0 6px 20px rgba(14,77,122,0.20);" : ""}
        >
          {btn.label}
          {btn.variant !== 'secondary' && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          )}
        </a>
      ))}
    </div>
  </div>
</section>
