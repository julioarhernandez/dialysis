---
import { WHY_REASONS } from '../data/about.js';
---
<section class="py-[88px] px-6 md:px-24 bg-tint">
  <div class="max-w-[1248px] mx-auto">

    <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">04 — Why choose us</div>
    <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[640px]" style="text-wrap:pretty;">
      Clinical excellence, paired with genuine human connection.
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-4 gap-4">
      {WHY_REASONS.map(r => (
        <div class="bg-white rounded-[18px] p-7 border border-hair flex flex-col gap-3.5 min-h-[200px]">
          <div class="w-11 h-11 rounded-[12px] bg-tint flex items-center justify-center text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={r.icon}/>
          </div>
          <h3 class="font-display font-medium text-[17px] m-0 tracking-[-0.012em] text-ink">{r.title}</h3>
          <p class="text-[13.5px] text-muted m-0 leading-[1.55]">{r.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
