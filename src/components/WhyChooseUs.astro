---
const reasons = [
  {
    title: 'Patient-centered approach',
    desc: 'Every decision made with your wellbeing and comfort as the top priority.',
    icon: `<circle cx="9" cy="9" r="3"/><circle cx="17" cy="11" r="2.5"/><path d="M3 19c0-3 3-5 6-5s6 2 6 5"/><path d="M14 19c.5-2 2.5-3.5 5-3.5"/>`,
  },
  {
    title: 'Experienced medical team',
    desc: 'Qualified specialists with deep expertise in renal care and dialysis management.',
    icon: `<path d="M12 3l8 3v5c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/>`,
  },
  {
    title: 'Advanced technology',
    desc: 'State-of-the-art equipment ensuring safe, effective, and comfortable treatments.',
    icon: `<rect x="6" y="6" width="12" height="12" rx="2"/><rect x="9" y="9" width="6" height="6" rx="1"/><path d="M9 3v3M15 3v3M9 18v3M15 18v3M3 9h3M3 15h3M18 9h3M18 15h3"/>`,
  },
  {
    title: 'Continuous support',
    desc: 'Ongoing follow-up care and accessible communication at every stage of treatment.',
    icon: `<path d="M5 4h4l2 5-3 1.5a11 11 0 0 0 5.5 5.5L15 13l5 2v4a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z"/>`,
  },
];
---
<section class="py-[88px] px-6 md:px-24 bg-tint">
  <div class="max-w-[1248px] mx-auto">

    <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">04 — Why choose us</div>
    <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[640px]" style="text-wrap:pretty;">
      Clinical excellence, paired with genuine human connection.
    </h2>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-4 gap-4">
      {reasons.map(r => (
        <div class="bg-white rounded-[18px] p-7 border border-hair flex flex-col gap-3.5 min-h-[200px]">
          <div class="w-11 h-11 rounded-[12px] bg-tint flex items-center justify-center text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={r.icon}/>
          </div>
          <h3 class="font-display font-medium text-[17px] m-0 tracking-[-0.012em] text-ink">{r.title}</h3>
          <p class="text-[13.5px] text-muted m-0 leading-[1.55]">{r.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>
