---
import { SITE, NAV_LINKS } from '../data/site.js';

const currentPath = Astro.url.pathname;

function isActive(href) {
  if (href === '/') return currentPath === '/';
  const base = href.split('#')[0];
  return base !== '/' && currentPath.startsWith(base);
}
---
<header class="sticky top-0 z-50 border-b border-hair" style="background:rgba(255,255,255,0.85);backdrop-filter:blur(14px);">
  <div class="max-w-[1440px] mx-auto px-5 py-3.5 md:px-16 md:py-[18px] flex items-center justify-between gap-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 no-underline">
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true">
        <defs>
          <linearGradient id="nav-logo-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#3fbac0"/>
            <stop offset="100%" stop-color="#0e4d7a"/>
          </linearGradient>
        </defs>
        <circle cx="18" cy="18" r="18" fill="url(#nav-logo-grad)"/>
        <path d="M18 8 C 24 14, 26 20, 18 26 C 10 20, 12 14, 18 8 Z" fill="rgba(255,255,255,0.95)"/>
      </svg>
      <div class="flex flex-col">
        <span class="font-display font-bold text-sm leading-none tracking-[-0.01em] text-ink">{SITE.shortName}</span>
        <span class="text-[11px] text-muted tracking-[0.04em]">Care Center</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex gap-[30px] text-sm" aria-label="Primary">
      {NAV_LINKS.map(link => (
        <a
          href={link.href}
          class={`no-underline transition-colors ${isActive(link.href) ? 'text-ink font-semibold' : 'text-muted font-medium hover:text-ink'}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div class="flex items-center gap-2.5">
      <a
        href={`tel:${SITE.contact.phone.replace(/\s/g, '')}`}
        class="hidden md:inline-flex items-center gap-1.5 text-[13px] text-muted no-underline hover:text-ink transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 4h4l2 5-3 1.5a11 11 0 0 0 5.5 5.5L15 13l5 2v4a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z"/>
        </svg>
        {SITE.contact.phone}
      </a>
      <a
        href="/contact"
        class="inline-flex items-center gap-2.5 px-[22px] py-[14px] rounded-[10px] bg-brand text-white font-semibold text-sm no-underline"
        style="box-shadow:0 1px 0 rgba(255,255,255,0.2) inset,0 6px 20px rgba(14,77,122,0.20);"
      >
        {SITE.navAction}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"/>
        </svg>
      </a>
      <button id="mobile-menu-btn" class="md:hidden p-0 ml-1 cursor-pointer bg-transparent border-none" aria-label="Open menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0a1a2c" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-hair bg-white px-5 pb-5 pt-3">
    <nav class="flex flex-col" aria-label="Mobile">
      {NAV_LINKS.map(link => (
        <a href={link.href} class="py-3 text-sm font-medium text-ink no-underline border-b border-hair last:border-0 hover:text-brand">
          {link.label}
        </a>
      ))}
    </nav>
    <div class="mt-4 pt-4 border-t border-hair text-sm text-muted">{SITE.contact.phone}</div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    btn?.addEventListener('click', () => {
      const isHidden = menu?.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isHidden));
    });
  });
</script>
