---
const items = [
  {
    title: 'Personalized care plans',
    desc: 'Every patient receives a tailored treatment plan built collaboratively with their medical team — fitting their unique health needs and lifestyle.',
    icon: `<path d="M12 3v6M12 15v6M3 12h6M15 12h6"/>`,
  },
  {
    title: 'Emotional & family support',
    desc: 'Dialysis affects the whole family. We provide resources, guidance, and emotional support for both patients and their loved ones.',
    icon: `<circle cx="9" cy="9" r="3"/><circle cx="17" cy="11" r="2.5"/><path d="M3 19c0-3 3-5 6-5s6 2 6 5"/><path d="M14 19c.5-2 2.5-3.5 5-3.5"/>`,
  },
  {
    title: 'Patient education & guidance',
    desc: 'We empower patients with knowledge about their condition, treatment options, and self-care so they can make informed decisions with confidence.',
    icon: `<path d="M12 3l8 3v5c0 5-3.5 8.5-8 10-4.5-1.5-8-5-8-10V6l8-3z"/>`,
  },
];
---
<section class="py-[88px] px-6 md:px-24 bg-white">
  <div class="max-w-[1248px] mx-auto grid grid-cols-1 md:grid-cols-[0.9fr_1.1fr] gap-10 md:gap-20 items-start">

    <!-- Left: sticky header + photo placeholder -->
    <div class="md:sticky md:top-[100px]">
      <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">03 — Patient care</div>
      <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[480px]" style="text-wrap:pretty;">
        Support that extends far beyond the clinical setting.
      </h2>
      <p class="mt-4 text-[17px] text-muted leading-[1.5]">
        "Patients are supported throughout their entire treatment journey — not just medically, but emotionally."
      </p>

      <!-- Photo placeholder -->
      <div class="mt-6 relative w-full rounded-[16px] overflow-hidden border border-hair" style="aspect-ratio:4/3;">
        <svg viewBox="0 0 200 150" preserveAspectRatio="none" class="w-full h-full block" aria-hidden="true">
          <defs>
            <pattern id="pc-photo" width="8" height="8" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
              <rect width="8" height="8" fill="#e6eff5"/>
              <line x1="0" y1="0" x2="0" y2="8" stroke="#0e4d7a" stroke-opacity="0.2" stroke-width="2"/>
            </pattern>
          </defs>
          <rect width="200" height="150" fill="url(#pc-photo)"/>
        </svg>
        <div class="absolute inset-0 flex items-center justify-center font-mono text-[11px] text-brand opacity-70 tracking-[0.04em]">
          care moment · placeholder
        </div>
      </div>
    </div>

    <!-- Right: care items -->
    <div class="flex flex-col gap-3">
      {items.map(item => (
        <div class="bg-white rounded-[18px] border border-hair p-6 flex gap-[18px] items-start">
          <div class="w-11 h-11 rounded-[12px] bg-tint flex-shrink-0 flex items-center justify-center text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon}/>
          </div>
          <div>
            <h3 class="font-display font-medium text-[19px] m-0 mb-1.5 tracking-[-0.012em] text-ink">{item.title}</h3>
            <p class="text-[14.5px] text-muted m-0 leading-[1.55]">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
