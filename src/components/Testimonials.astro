---
import { TESTIMONIALS } from '../data/testimonials.js';
---
<section class="py-[88px] px-6 md:px-24 bg-white reveal">
  <div class="max-w-[1248px] mx-auto">

    <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">05 — Patient stories</div>
    <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0">Real stories. Real trust.</h2>
    <p class="mt-4 text-[17px] text-muted max-w-[640px] leading-[1.5]">
      The most powerful form of confidence comes from the patients we walk beside every day.
    </p>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-[18px]">
      {TESTIMONIALS.map(t => (
        <figure class="bg-white rounded-[20px] p-7 border border-hair m-0 flex flex-col gap-5 min-h-[280px]">
          <div class="font-display text-[36px] leading-[0.5] text-aqua font-bold">"</div>
          <blockquote class="m-0 font-display font-medium text-[19px] leading-[1.4] text-ink tracking-[-0.01em] flex-1" style="text-wrap:pretty;">
            {t.quote}
          </blockquote>
          <figcaption class="flex items-center gap-3">
            <svg width="42" height="42" viewBox="0 0 56 56" style="display:block;border-radius:50%;flex-shrink:0;" aria-hidden="true">
              <defs>
                <pattern id={t.patId} width="6" height="6" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
                  <rect width="6" height="6" fill="#e6eff5"/>
                  <line x1="0" y1="0" x2="0" y2="6" stroke="#0e4d7a" stroke-opacity="0.25" stroke-width="2"/>
                </pattern>
              </defs>
              <circle cx="28" cy="28" r="28" fill={`url(#${t.patId})`}/>
              <text x="28" y="32" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#0e4d7a" fill-opacity="0.7">{t.initials}</text>
            </svg>
            <div>
              <div class="text-[13.5px] font-semibold text-ink">{t.name}</div>
              <div class="text-xs text-muted">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>

  </div>
</section>
