---
import { SITE } from '../data/site.js';
import { icons } from '../data/icons.js';

const { contact, web3formsKey } = SITE;
---
<section class="py-[88px] px-6 md:px-24 bg-white">
  <div class="max-w-[1248px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-start">

    <!-- Left: info -->
    <div>
      <div class="font-mono text-[11px] text-brand tracking-[0.16em] uppercase mb-4">08 — Schedule a consultation</div>
      <h2 class="font-display font-medium text-[38px] leading-[1.1] tracking-[-0.022em] text-ink m-0 max-w-[460px]" style="text-wrap:pretty;">
        Take the next step — at your pace.
      </h2>
      <p class="mt-4 text-[17px] text-muted leading-[1.5]">
        Reach out and a member of our care team will respond within one business day.
      </p>

      <div class="mt-8 flex flex-col gap-[18px]">

        <!-- Call -->
        <div class="flex items-start gap-4">
          <div class="w-[42px] h-[42px] rounded-[12px] bg-tint flex items-center justify-center flex-shrink-0 text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.call}/>
          </div>
          <div>
            <div class="font-mono text-[11px] text-muted tracking-[0.1em] uppercase">Call</div>
            <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="font-display font-medium text-[18px] text-ink mt-0.5 block no-underline hover:text-brand">
              {contact.phone}
            </a>
            <div class="text-[13px] text-muted mt-0.5">{contact.hours}</div>
          </div>
        </div>

        <!-- Email -->
        <div class="flex items-start gap-4">
          <div class="w-[42px] h-[42px] rounded-[12px] bg-tint flex items-center justify-center flex-shrink-0 text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.mail}/>
          </div>
          <div>
            <div class="font-mono text-[11px] text-muted tracking-[0.1em] uppercase">Email</div>
            <a href={`mailto:${contact.email}`} class="font-display font-medium text-[18px] text-ink mt-0.5 block no-underline hover:text-brand">
              {contact.email}
            </a>
            <div class="text-[13px] text-muted mt-0.5">We respond within 1 business day</div>
          </div>
        </div>

        <!-- Visit -->
        <div class="flex items-start gap-4">
          <div class="w-[42px] h-[42px] rounded-[12px] bg-tint flex items-center justify-center flex-shrink-0 text-brand">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.pin}/>
          </div>
          <div>
            <div class="font-mono text-[11px] text-muted tracking-[0.1em] uppercase">Visit</div>
            <div class="font-display font-medium text-[18px] text-ink mt-0.5">{contact.address}</div>
            <div class="text-[13px] text-muted mt-0.5">{contact.city}, {contact.state} {contact.zip}</div>
          </div>
        </div>

      </div>
    </div>

    <!-- Right: form -->
    <form class="bg-white rounded-[20px] p-6 md:p-9 border border-hair flex flex-col gap-4" id="contact-form" novalidate>
      <!-- Web3Forms required fields -->
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="New consultation request — Global Dialysis Care Center" />
      <input type="hidden" name="from_name" value="Global Dialysis Care Center Website" />
      <!-- Web3Forms built-in honeypot -->
      <input type="checkbox" name="botcheck" style="display:none;" tabindex="-1" aria-hidden="true" />

      <!--
        Off-screen CSS honeypots — positioned out of view so real users never see them.
        Bots crawl the DOM and fill any input regardless of visual position.
        Do NOT use display:none — sophisticated bots skip those on purpose.
      -->
      <div aria-hidden="true" style="position:absolute;left:-9999px;top:0;width:1px;height:1px;overflow:hidden;pointer-events:none;tab-index:-1;">
        <label>Leave blank <input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        <label>Leave blank <input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3.5">
        <label class="flex flex-col gap-1.5">
          <span class="text-[12.5px] font-semibold text-ink tracking-[-0.005em]">First name</span>
          <input type="text" name="first_name" placeholder="Sarah" required
            class="appearance-none font-sans px-3.5 py-3 rounded-[10px] border border-hair bg-white text-ink text-sm outline-none focus:border-brand transition-colors" />
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-[12.5px] font-semibold text-ink tracking-[-0.005em]">Last name</span>
          <input type="text" name="last_name" placeholder="Mitchell" required
            class="appearance-none font-sans px-3.5 py-3 rounded-[10px] border border-hair bg-white text-ink text-sm outline-none focus:border-brand transition-colors" />
        </label>
      </div>
      <label class="flex flex-col gap-1.5">
        <span class="text-[12.5px] font-semibold text-ink tracking-[-0.005em]">Email</span>
        <input type="email" name="email" placeholder="sarah@example.com" required
          class="appearance-none font-sans px-3.5 py-3 rounded-[10px] border border-hair bg-white text-ink text-sm outline-none focus:border-brand transition-colors" />
      </label>
      <label class="flex flex-col gap-1.5">
        <span class="text-[12.5px] font-semibold text-ink tracking-[-0.005em]">Phone</span>
        <input type="tel" name="phone" placeholder="(305) 555-0123"
          class="appearance-none font-sans px-3.5 py-3 rounded-[10px] border border-hair bg-white text-ink text-sm outline-none focus:border-brand transition-colors" />
      </label>
      <label class="flex flex-col gap-1.5">
        <span class="text-[12.5px] font-semibold text-ink tracking-[-0.005em]">What can we help with?</span>
        <textarea name="message" rows="4" placeholder="I'd like to learn about home dialysis options…"
          class="appearance-none font-sans px-3.5 py-3 rounded-[10px] border border-hair bg-white text-ink text-sm outline-none focus:border-brand transition-colors resize-y"></textarea>
      </label>
      <button
        type="submit"
        id="submit-btn"
        class="w-full inline-flex items-center justify-center gap-2.5 px-[22px] py-[14px] rounded-[10px] bg-brand text-white font-semibold text-sm cursor-pointer border-none disabled:opacity-60 disabled:cursor-not-allowed transition-opacity"
        style="box-shadow:0 1px 0 rgba(255,255,255,0.2) inset,0 6px 20px rgba(14,77,122,0.20);"
      >
        <span id="btn-label">Schedule a consultation</span>
        <span id="btn-spinner" class="hidden w-4 h-4 border-2 border-white/40 border-t-white rounded-full animate-spin"></span>
        <svg id="btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={icons.arrow}/>
      </button>

      <!-- Error message -->
      <p id="form-error" class="hidden text-sm text-red-600 text-center m-0 font-medium"></p>

      <p class="text-xs text-muted text-center m-0">Confidential. We never share your information.</p>
    </form>

    <!-- Success state (replaces form) -->
    <div id="form-success" class="hidden bg-white rounded-[20px] p-6 md:p-9 border border-hair flex flex-col items-center justify-center gap-5 text-center min-h-[320px]">
      <div class="w-14 h-14 rounded-full bg-tint flex items-center justify-center text-brand">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5 9-11"/></svg>
      </div>
      <div>
        <h3 class="font-display font-medium text-[22px] text-ink tracking-[-0.015em] m-0 mb-2">Message received!</h3>
        <p class="text-[15px] text-muted m-0 max-w-[340px]">
          A member of our care team will be in touch within one business day.
        </p>
      </div>
    </div>

  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const form       = document.getElementById('contact-form') as HTMLFormElement;
    const submitBtn  = document.getElementById('submit-btn')   as HTMLButtonElement;
    const btnLabel   = document.getElementById('btn-label')    as HTMLElement;
    const btnSpinner = document.getElementById('btn-spinner')  as HTMLElement;
    const btnArrow   = document.getElementById('btn-arrow')    as HTMLElement;
    const formError  = document.getElementById('form-error')   as HTMLElement;
    const formSuccess = document.getElementById('form-success') as HTMLElement;

    // Record when the page loaded — used for the timing trap below.
    const PAGE_LOAD_TIME = Date.now();

    // URL pattern: catches http://, https://, and bare www. links.
    const URL_PATTERN = /(https?:\/\/|www\.)\S+/i;

    // Silently show the success screen without submitting.
    // Bots see a "success" and move on — we give them no signal that they were caught.
    function silentFail() {
      form.classList.add('hidden');
      formSuccess.classList.remove('hidden');
    }

    function showError(msg: string) {
      formError.textContent = msg;
      formError.classList.remove('hidden');
      submitBtn.disabled = false;
      btnLabel.textContent = 'Schedule a consultation';
      btnSpinner.classList.add('hidden');
      btnArrow.classList.remove('hidden');
    }

    function setLoading() {
      formError.classList.add('hidden');
      submitBtn.disabled = true;
      btnLabel.textContent = 'Sending…';
      btnSpinner.classList.remove('hidden');
      btnArrow.classList.add('hidden');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      setLoading();

      // ── Trap 1: timing ────────────────────────────────────────
      // Real humans take at least a few seconds to fill a form.
      // Anything under 3 s is almost certainly a bot.
      if (Date.now() - PAGE_LOAD_TIME < 3000) {
        silentFail();
        return;
      }

      // ── Trap 2: CSS honeypot fields ───────────────────────────
      // These inputs are visually off-screen; only bots fill them.
      const websiteField = (form.querySelector('[name="website"]') as HTMLInputElement)?.value;
      const companyField = (form.querySelector('[name="company"]') as HTMLInputElement)?.value;
      if (websiteField || companyField) {
        silentFail();
        return;
      }

      // ── Guard: URL in message ─────────────────────────────────
      // Spam almost always contains links. Real patients don't paste URLs.
      const message = (form.querySelector('[name="message"]') as HTMLTextAreaElement)?.value ?? '';
      if (URL_PATTERN.test(message)) {
        showError('Please remove any links from your message — we accept plain text only.');
        return;
      }

      // ── Submit to Web3Forms ───────────────────────────────────
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await res.json();

        if (data.success) {
          form.classList.add('hidden');
          formSuccess.classList.remove('hidden');
        } else {
          throw new Error(data.message || 'Submission failed.');
        }
      } catch (err) {
        showError(err instanceof Error ? err.message : 'Something went wrong. Please try again.');
      }
    });
  });
</script>
